{
	"name": "cloudfire",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run db:studio:local\"",
		"dev:backend": "wrangler pages dev",
		"dev:frontend": "vite build --watch",
		"build": "npm run format && tsc -b && vite build",
		"cf:deploy": "npm run build && wrangler pages deploy",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply cloudfire-prod-db --local",
		"db:migrate:preview": "wrangler d1 migrations apply --env preview cloudfire-preview-db --remote",
		"db:migrate:prod": "wrangler d1 migrations apply cloudfire-prod-db --remote",
		"db:studio:local": "cross-env LOCAL_DB_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) drizzle-kit studio",
		"db:studio:preview": "source .env && cross-env $(grep -m 2 \"^database_id=\" wrangler.toml | tail -n1) drizzle-kit studio",
		"db:studio:prod": "source .env && cross-env $(grep -m 1 \"^database_id=\" wrangler.toml) drizzle-kit studio",
		"format": "biome format --write src",
		"npm:audit": "npx better-npm-audit audit",
		"npm:check": "npx npm-check -u",
		"cz": "npx cz",
		"release": "npm run build && branch=$(git branch --show-current); if [[ $branch == 'master' || $branch == 'main' ]]; then commit-and-tag-version; else echo 'Releases allowed from main branch only'; exit 1; fi;",
		"prepare": "husky"
	},
	"dependencies": {
		"@hono/swagger-ui": "^0.4.0",
		"@hono/zod-openapi": "^0.15.0",
		"@hono/zod-validator": "^0.2.2",
		"@hookform/resolvers": "^3.9.0",
		"@radix-ui/react-avatar": "^1.1.0",
		"@radix-ui/react-checkbox": "^1.1.1",
		"@radix-ui/react-collapsible": "^1.1.0",
		"@radix-ui/react-dialog": "^1.1.1",
		"@radix-ui/react-dropdown-menu": "^2.1.1",
		"@radix-ui/react-label": "^2.1.0",
		"@radix-ui/react-popover": "^1.1.1",
		"@radix-ui/react-select": "^2.1.1",
		"@radix-ui/react-separator": "^1.1.0",
		"@radix-ui/react-slot": "^1.1.0",
		"@radix-ui/react-tabs": "^1.1.0",
		"@radix-ui/react-toast": "^1.2.1",
		"@radix-ui/react-tooltip": "^1.1.2",
		"@tanstack/react-table": "^8.19.3",
		"bcryptjs": "^2.4.3",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.1",
		"concurrently": "^8.2.2",
		"date-fns": "^3.6.0",
		"drizzle-orm": "^0.32.1",
		"drizzle-zod": "^0.5.1",
		"hono": "^4.5.0",
		"lucide-react": "^0.416.0",
		"react": "^18.3.1",
		"react-day-picker": "^9.0.4",
		"react-dom": "^18.3.1",
		"react-hook-form": "^7.52.1",
		"react-router-dom": "^6.25.1",
		"tailwind-merge": "^2.4.0",
		"tailwindcss-animate": "^1.0.7",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "1.8.3",
		"@cloudflare/workers-types": "^4.20240725.0",
		"@commitlint/cli": "^19.3.0",
		"@commitlint/config-conventional": "^19.2.2",
		"@types/bcryptjs": "^2.4.6",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.1",
		"autoprefixer": "^10.4.19",
		"better-sqlite3": "^11.1.2",
		"commit-and-tag-version": "^12.4.1",
		"cross-env": "^7.0.3",
		"cz-conventional-changelog": "^3.3.0",
		"devmoji": "^2.3.0",
		"drizzle-kit": "^0.23.1",
		"husky": "^9.1.1",
		"postcss": "^8.4.40",
		"tailwindcss": "^3.4.7",
		"typescript": "^5.2.2",
		"vite": "^5.3.4",
		"wrangler": "^3.65.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"commitlint": {
		"extends": ["@commitlint/config-conventional"]
	}
}
