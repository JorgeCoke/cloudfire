{
	"name": "cloudfire",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"format": "biome format --write src",
		"preview": "vite preview",
		"npm:audit": "npx better-npm-audit audit",
		"npm:check": "npx npm-check -u",
		"release": "branch=$(git branch --show-current); if [[ $branch == 'master' || $branch == 'main' ]]; then commit-and-tag-version; else echo 'Releases allowed from main branch only'; exit 1; fi;",
		"cz": "npx cz",
		"devmoji": "devmoji -e --lint",
		"prepare": "husky"
	},
	"dependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "1.8.3",
		"@commitlint/cli": "^19.3.0",
		"@commitlint/config-conventional": "^19.2.2",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.1",
		"commit-and-tag-version": "^12.4.1",
		"cz-conventional-changelog": "^3.3.0",
		"devmoji": "^2.3.0",
		"husky": "^9.1.1",
		"typescript": "^5.2.2",
		"vite": "^5.3.4"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"commitlint": {
		"extends": ["@commitlint/config-conventional"]
	}
}
